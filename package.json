{
  "name": "session-bus",
  "version": "0.1.0",
  "description": "Cross-channel/session memory synchronization plugin for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["openclaw", "plugin", "session", "memory", "sync"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LucianFord/session-bus.git"
  },
  "files": [
    "dist/",
    "index.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@sinclair/typebox": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
